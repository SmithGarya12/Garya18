pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                echo 'I am Cloning repository'
            }
        }

        stage('Build') {
            steps {
                echo 'Here we are Building project'
            }
        }

        stage('Test') {
            steps {
                echo 'We see the Running tests'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Last we are Deploying application'
            }
        }
    }
}
